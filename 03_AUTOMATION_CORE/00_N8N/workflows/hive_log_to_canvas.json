{
  "name": "Hive Log to Slack Canvas",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hive-log-to-canvas",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "create",
        "name": "={{$node["Webhook"].json["filename"]}}",
        "content": "={{$node["Webhook"].json["content"]}}",
        "options": {}
      },
      "name": "Google Docs",
      "type": "n8n-nodes-base.googleDocs",
      "typeVersion": 1,
      "position": [450, 300],
      "credentials": {
        "googleApi": "google_api_creds"
      }
    },
    {
      "parameters": {
        "channel": "ai-war-room",
        "text": "🤖 *Hive Mind Execution Complete*
*Task:* {{$node["Webhook"].json["filename"]}}
*Timestamp:* {{$node["Webhook"].json["timestamp"]}}
📄 *[Click here to view the full Report Canvas]({{$node["Google Docs"].json["webViewLink"]}})*",
        "options": {}
      },
      "name": "Slack",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [650, 300],
      "credentials": {
        "slackApi": "slack_api_creds"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Google Docs",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Docs": {
      "main": [
        [
          {
            "node": "Slack",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
