#!/bin/bash
#
# CDE_BOT Control Script (cb)
# Usage: cb [start|stop|status|logs|restart]
#

BOT_DIR="/mnt/sdcard/AA_MY_DRIVE/03_AUTOMATION_CORE/01_Scripts/crypto_bot"
PID_FILE="$BOT_DIR/data/bot.pid"
LOG_FILE="$BOT_DIR/logs/bot_$(date +%Y%m%d).log"
LOCK_FILE="$BOT_DIR/data/bot.lock"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Ensure data directory exists
mkdir -p "$BOT_DIR/data"
mkdir -p "$BOT_DIR/logs"

check_running() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            return 0  # Running
        else
            rm -f "$PID_FILE" "$LOCK_FILE"
            # stale PID, fall through to scan
        fi
    fi
    # Fallback: if the bot was started outside cb (or PID file got wiped), recover it.
    # Validate by checking open fds for our bot console log to avoid matching unrelated "bot.py" processes.
    FOUND=""
    for CAND in $(pgrep -f "python3 bot.py" 2>/dev/null || true) $(pgrep -f "python3 .*crypto_bot/bot.py" 2>/dev/null || true); do
        if ! ps -p "$CAND" > /dev/null 2>&1; then
            continue
        fi
        for FD in /proc/"$CAND"/fd/*; do
            TGT="$(readlink "$FD" 2>/dev/null || true)"
            if [ "$TGT" = "$BOT_DIR/logs/bot_console.log" ]; then
                FOUND="$CAND"
                break
            fi
        done
        if [ -n "${FOUND:-}" ]; then
            break
        fi
    done
    if [ -n "${FOUND:-}" ]; then
        echo "$FOUND" > "$PID_FILE"
        return 0
    fi
    return 1
}

check_other_instances() {
    # Check for other trading bots or agents
    OTHER_BOTS=$(pgrep -f "crypto_bot|trading_bot|coinbase" | grep -v $$ | wc -l)
    if [ "$OTHER_BOTS" -gt 0 ]; then
        echo -e "${YELLOW}WARNING: Found $OTHER_BOTS other trading-related processes running${NC}"
        echo "Running processes:"
        pgrep -af "crypto_bot|trading_bot|coinbase" | grep -v $$
        echo ""
    fi
}

start_bot() {
    echo -e "${BLUE}=== CDE_BOT Startup ===${NC}"

    # Check if already running
    if check_running; then
        echo -e "${YELLOW}Bot is already running (PID: $(cat $PID_FILE))${NC}"
        echo "Use 'cb status' for details or 'cb restart' to restart"
        return 1
    fi

    # Check for lock file (prevents race conditions)
    if [ -f "$LOCK_FILE" ]; then
        LOCK_TIME=$(cat "$LOCK_FILE")
        echo -e "${YELLOW}Lock file exists (created: $LOCK_TIME)${NC}"
        echo "Another instance may be starting. Wait or run 'cb stop' first."
        return 1
    fi

    # Check for other bots
    check_other_instances

    # Create lock
    date > "$LOCK_FILE"

    echo -e "${GREEN}Starting CDE_BOT...${NC}"
    echo "Log file: $LOG_FILE"

    # Change to bot directory
    cd "$BOT_DIR"

    # Start bot in background with nohup
    nohup python3 "$BOT_DIR/bot.py" --interval 30 >> "$LOG_FILE" 2>&1 &
    BOT_PID=$!

    # Save PID
    echo $BOT_PID > "$PID_FILE"

    # Wait a moment and verify it started
    sleep 2

    if ps -p $BOT_PID > /dev/null 2>&1; then
        echo -e "${GREEN}Bot started successfully!${NC}"
        echo "PID: $BOT_PID"
        echo ""
        echo "Commands:"
        echo "  cb status  - Check bot status"
        echo "  cb logs    - View live logs"
        echo "  cb stop    - Stop the bot"

        # Remove lock
        rm -f "$LOCK_FILE"
        return 0
    else
        echo -e "${RED}Bot failed to start! Check logs:${NC}"
        tail -20 "$LOG_FILE"
        rm -f "$PID_FILE" "$LOCK_FILE"
        return 1
    fi
}

stop_bot() {
    echo -e "${BLUE}=== Stopping CDE_BOT ===${NC}"

    if ! check_running; then
        # Try to stop any stray instance with a path match (safer than killing all bot.py).
        STRAY=""
        for CAND in $(pgrep -f "python3 bot.py" 2>/dev/null || true) $(pgrep -f "python3 .*crypto_bot/bot.py" 2>/dev/null || true); do
            if ! ps -p "$CAND" > /dev/null 2>&1; then
                continue
            fi
            for FD in /proc/"$CAND"/fd/*; do
                TGT="$(readlink "$FD" 2>/dev/null || true)"
                if [ "$TGT" = "$BOT_DIR/logs/bot_console.log" ]; then
                    STRAY="$CAND"
                    break
                fi
            done
            if [ -n "${STRAY:-}" ]; then
                break
            fi
        done
        if [ -n "${STRAY:-}" ] && ps -p "$STRAY" > /dev/null 2>&1; then
            echo "Stopping stray bot instance (PID: $STRAY)..."
            kill -TERM "$STRAY" 2>/dev/null || true
        else
            echo -e "${YELLOW}Bot is not running${NC}"
        fi
        rm -f "$PID_FILE" "$LOCK_FILE"
        return 0
    fi

    PID=$(cat "$PID_FILE")
    echo "Stopping bot (PID: $PID)..."

    # Graceful shutdown
    kill -TERM "$PID" 2>/dev/null

    # Wait for graceful shutdown (up to 10 seconds)
    for i in {1..10}; do
        if ! ps -p "$PID" > /dev/null 2>&1; then
            echo -e "${GREEN}Bot stopped gracefully${NC}"
            rm -f "$PID_FILE" "$LOCK_FILE"
            return 0
        fi
        sleep 1
        echo -n "."
    done

    # Force kill if still running
    echo ""
    echo "Force stopping..."
    kill -9 "$PID" 2>/dev/null
    sleep 1

    rm -f "$PID_FILE" "$LOCK_FILE"
    echo -e "${GREEN}Bot stopped${NC}"
}

show_status() {
    echo -e "${BLUE}=== CDE_BOT Status ===${NC}"
    echo ""

    if check_running; then
        PID=$(cat "$PID_FILE")
        echo -e "Status: ${GREEN}RUNNING${NC}"
        echo "PID: $PID"

        # Show process info
        echo ""
        echo "Process Info:"
        ps -p "$PID" -o pid,etime,rss,args --no-headers 2>/dev/null | head -1

        # Show memory usage
        MEM=$(ps -p "$PID" -o rss --no-headers 2>/dev/null | tr -d ' ')
        if [ -n "$MEM" ]; then
            MEM_MB=$((MEM / 1024))
            echo "Memory: ${MEM_MB}MB"
        fi

        # Show uptime
        UPTIME=$(ps -p "$PID" -o etime --no-headers 2>/dev/null | tr -d ' ')
        echo "Uptime: $UPTIME"

    else
        echo -e "Status: ${RED}STOPPED${NC}"
    fi

    echo ""
    echo "Log file: $LOG_FILE"

    # Show last few log lines
    if [ -f "$LOG_FILE" ]; then
        echo ""
        echo "Recent activity:"
        tail -5 "$LOG_FILE" 2>/dev/null
    fi

    # Check for other bots
    echo ""
    check_other_instances
}

show_logs() {
    echo -e "${BLUE}=== CDE_BOT Logs (Ctrl+C to exit) ===${NC}"
    echo "Log file: $LOG_FILE"
    echo ""

    if [ -f "$LOG_FILE" ]; then
        tail -f "$LOG_FILE"
    else
        echo -e "${YELLOW}No log file found${NC}"
    fi
}

restart_bot() {
    echo -e "${BLUE}=== Restarting CDE_BOT ===${NC}"
    stop_bot
    sleep 2
    start_bot
}

start_daemon() {
    echo -e "${BLUE}=== Starting CDE_BOT Daemon (24/7 Mode) ===${NC}"

    WATCHDOG_PID_FILE="$BOT_DIR/data/watchdog.pid"

    # Check if watchdog already running
    if [ -f "$WATCHDOG_PID_FILE" ]; then
        WD_PID=$(cat "$WATCHDOG_PID_FILE")
        if ps -p "$WD_PID" > /dev/null 2>&1; then
            echo -e "${YELLOW}Watchdog already running (PID: $WD_PID)${NC}"
            return 1
        fi
    fi

    # Start watchdog in background (SD card is typically mounted noexec; run via bash)
    nohup bash "$BOT_DIR/watchdog.sh" >> "$BOT_DIR/logs/watchdog.log" 2>&1 &
    WD_PID=$!
    echo $WD_PID > "$WATCHDOG_PID_FILE"

    echo -e "${GREEN}Daemon started (Watchdog PID: $WD_PID)${NC}"
    echo "The bot will automatically restart if it crashes."
    echo ""
    echo "Use 'cb stop-daemon' to stop 24/7 mode"
}

stop_daemon() {
    echo -e "${BLUE}=== Stopping CDE_BOT Daemon ===${NC}"

    WATCHDOG_PID_FILE="$BOT_DIR/data/watchdog.pid"

    if [ -f "$WATCHDOG_PID_FILE" ]; then
        WD_PID=$(cat "$WATCHDOG_PID_FILE")
        if ps -p "$WD_PID" > /dev/null 2>&1; then
            kill -TERM "$WD_PID" 2>/dev/null
            echo -e "${GREEN}Watchdog stopped${NC}"
        fi
        rm -f "$WATCHDOG_PID_FILE"
    fi

    # Also stop the bot itself
    stop_bot
}

# Main command handler
case "${1:-start}" in
    start)
        start_bot
        ;;
    stop)
        stop_bot
        ;;
    status)
        show_status
        ;;
    logs|log)
        show_logs
        ;;
    restart)
        restart_bot
        ;;
    daemon|24/7)
        start_daemon
        ;;
    stop-daemon)
        stop_daemon
        ;;
    *)
        echo -e "${BLUE}CDE_BOT Control${NC}"
        echo ""
        echo "Usage: cb [command]"
        echo ""
        echo "Commands:"
        echo "  start       Start the trading bot (default)"
        echo "  stop        Stop the trading bot"
        echo "  status      Show bot status and recent activity"
        echo "  logs        Follow live log output"
        echo "  restart     Restart the bot"
        echo "  daemon      Start 24/7 mode (auto-restart on crash)"
        echo "  stop-daemon Stop 24/7 mode and the bot"
        echo ""
        echo "The bot only trades when ALL conditions are met:"
        echo "  - Trading hours (08-10, 13-16 UTC)"
        echo "  - No news events (FOMC, CPI)"
        echo "  - 3+ confluence signals"
        echo "  - Momentum confirmed (RSI, MACD, VWAP)"
        echo "  - Volume spike (1.5x+ average)"
        echo "  - R:R ratio >= 2.5:1"
        echo ""
        ;;
esac
