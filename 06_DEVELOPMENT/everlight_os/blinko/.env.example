# Blinko Environment Config for Everlight Hive Mind
# Copy to .env and update values before deploying

# Database password (change this!)
BLINKO_DB_PASS=blinko_secure_pass

# NextAuth secret (change this!)
BLINKO_SECRET=everlight_blinko_secret_change_me

# Public URL (update for Oracle Cloud deployment)
# BLINKO_PUBLIC_URL=http://your-oracle-vm-ip:1111
